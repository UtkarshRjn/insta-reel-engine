# OpenAI API Key (for script generation)
OPENAI_API_KEY=your_openai_api_key_here

# Grok (xAI Aurora) API Key (for video generation)
# Get your key at: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Cloudflare R2 (for video hosting - Instagram needs public URLs)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=reel-engine
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Instagram/Meta App Credentials
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/auth/instagram/callback

# Scheduler
DAILY_POST_TIME=09:00

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:5173

# For Railway: set DATA_DIR to a persistent volume path
# DATA_DIR=/data
